<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name="com.saigonphantomlabs.MyApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Chess">

        <!-- Khai báo AdMob App ID Roy ok-->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3612191981543807~4706041811" />



        <activity
            android:name="com.saigonphantomlabs.ChessBoardActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Chess" />
        <activity android:name="com.saigonphantomlabs.PawnPromotionActivity" />
        <activity
            android:name="com.saigonphantomlabs.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Chess" />
        <activity
            android:name="com.saigonphantomlabs.SplashActivity"
            android:exported="true"
            android:theme="@style/SplashTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
