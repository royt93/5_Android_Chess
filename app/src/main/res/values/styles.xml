<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Custom Dialog Animation Style -->
    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit</item>
    </style>

    <!-- Custom Dialog Theme -->
    <style name="CustomDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:windowAnimationStyle">@style/DialogAnimation</item>
        <item name="materialAlertDialogTitleTextStyle">@style/CustomDialogTitle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/CustomDialogBody</item>
        <item name="android:backgroundDimAmount">0.6</item>
    </style>

    <!-- Custom Dialog Title Style -->
    <style name="CustomDialogTitle" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#D32F2F</item>
    </style>

    <!-- Custom Dialog Body Style -->
    <style name="CustomDialogBody" parent="MaterialAlertDialog.Material3.Body.Text">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#424242</item>
    </style>

    <!-- Project Common Styles: Typography -->
    <style name="GameText" parent="Widget.AppCompat.TextView">
        <item name="android:fontFamily">@font/exo2</item>
        <item name="android:textColor">@color/game_white_piece</item>
    </style>

    <style name="GameText.Title">
        <item name="android:fontFamily">@font/cinzel</item>
        <item name="android:textColor">@color/game_gold_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:shadowColor">@color/game_gold_glow</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">16</item>
    </style>

    <style name="GameText.Subtitle">
        <item name="android:fontFamily">@font/cinzel</item>
        <item name="android:textColor">@color/game_gold_light</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="GameText.Body">
        <item name="android:fontFamily">@font/exo2</item>
        <item name="android:textColor">@color/game_text_muted</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="GameText.Label">
        <item name="android:fontFamily">@font/exo2</item>
        <item name="android:textColor">@color/game_neon_cyan</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>