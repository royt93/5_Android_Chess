<resources>

    <!-- Theme for main flow -->
    <style name="Theme.Chess" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/game_gold_primary</item>
        <item name="colorPrimaryVariant">@color/game_gold_dark</item>
        <item name="colorOnPrimary">@color/game_bg_deep</item>
        <item name="colorSecondary">@color/game_neon_cyan</item>
        <item name="colorSecondaryVariant">@color/game_blue_info</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/game_bg_deep</item>
        <item name="android:navigationBarColor">@color/game_bg_deep</item>
        <item name="android:windowBackground">@color/game_bg_deep</item>
        <!-- Hero animation: bật shared element transition giữa các activity. -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
        <item name="android:windowSharedElementsUseOverlay">true</item>
    </style>

    <!-- VIP screen: ép Dark cố định. Màn VIP luôn nền tối (game_bg_deep) bất kể
         DayNight, nên phải khoá colorSurface/onSurface/outline về tông tối để mọi
         component Material (TextInputLayout, button…) không lấy màu sáng mặc định ở
         light mode → tránh chữ/nút tối-trên-nền-tối (vô hình). -->
    <style name="Theme.Chess.Vip" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/vip_gold</item>
        <item name="colorOnPrimary">@color/vip_on_gold</item>
        <item name="colorSecondary">@color/game_neon_cyan</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/game_bg_surface</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnSurfaceVariant">@color/vip_text_secondary</item>
        <item name="colorOutline">@color/vip_text_secondary</item>
        <item name="android:statusBarColor">@color/game_bg_deep</item>
        <item name="android:navigationBarColor">@color/game_bg_deep</item>
        <item name="android:windowBackground">@color/game_bg_deep</item>
        <!-- Hero animation: bật shared element transition (Main → Vip). -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
        <item name="android:windowSharedElementsUseOverlay">true</item>
    </style>

    <!-- Splash Theme -->
    <style name="SplashTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">false</item>
        <!-- Temporary use background color as we will handle background in layout XML -->
        <item name="android:windowBackground">@color/game_bg_deep</item>
        <item name="android:navigationBarColor">@color/game_bg_deep</item>
        <item name="android:statusBarColor">@color/game_bg_deep</item>
        <!-- Hero animation: Splash là nguồn của logo hero (ivLogo → Main ivMainLogo). -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
        <item name="android:windowSharedElementsUseOverlay">true</item>
    </style>
</resources>