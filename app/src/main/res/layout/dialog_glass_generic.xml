<?xml version="1.0" encoding="utf-8"?>
<!--
  Generic Dialog — Cyberpunk Glassmorphism
  Rule: ALL margin/padding = 16dp base unit
  No scale > 1.0. No negative insets.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:background="@drawable/bg_dialog_glass"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- Top accent bar: thin neon line at very top -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@drawable/bg_dialog_top_bar" />

    <!-- Content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="0dp">

        <!-- Icon container with glow halo -->
        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginBottom="16dp"
            android:layout_gravity="center_horizontal">

            <!-- Radial glow behind icon -->
            <View
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_dialog_icon_halo" />

            <!-- Icon ring border -->
            <View
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_dialog_icon_ring" />

            <ImageView
                android:id="@+id/dialog_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_warning_ember"
                app:tint="@color/game_gold_primary" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/dialog_title"
            style="@style/GameText.Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="Title"
            android:shadowColor="@color/game_gold_glow"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="16" />

        <!-- Divider -->
        <View
            android:layout_width="48dp"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="#60D4AF37" />

        <!-- Message -->
        <TextView
            android:id="@+id/dialog_message"
            style="@style/GameText.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:text="Message body..." />

    </LinearLayout>

    <!-- Bottom divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF" />

    <!-- Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_negative"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fontFamily="@font/exo2"
            android:text="CANCEL"
            android:textColor="#99FFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.05"
            app:cornerRadius="0dp"
            app:rippleColor="#20FFFFFF" />

        <!-- Vertical divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:background="#1AFFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_positive"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fontFamily="@font/cinzel"
            android:text="OK"
            android:textColor="@color/game_gold_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:shadowColor="@color/game_gold_glow"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="8"
            app:cornerRadius="0dp"
            app:rippleColor="#20FFD700" />

    </LinearLayout>

</LinearLayout>
