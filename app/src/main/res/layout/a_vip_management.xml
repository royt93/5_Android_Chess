<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/game_bg_deep"
    tools:context="com.saigonphantomlabs.feature.vip.VipActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top app bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?selectableItemBackgroundBorderless"
                android:contentDescription="@string/cancel"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:transitionName="hero_vip"
                android:text="@string/vip_title"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/contentContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="32dp">

                <!-- [1] Status header / Hero card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStatusHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:id="@+id/headerBg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_vip_status_header_free"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="28dp">

                        <com.facebook.shimmer.ShimmerFrameLayout
                            android:id="@+id/shimmerCrown"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:id="@+id/ivCrown"
                                android:layout_width="84dp"
                                android:layout_height="84dp"
                                android:background="@drawable/bg_vip_crown_badge"
                                android:contentDescription="@string/vip_title"
                                android:padding="16dp"
                                android:src="@drawable/ic_workspace_premium"
                                app:tint="@color/white" />
                        </com.facebook.shimmer.ShimmerFrameLayout>

                        <TextView
                            android:id="@+id/tvStatusTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:letterSpacing="0.01"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="VIP Active" />

                        <TextView
                            android:id="@+id/tvStatusSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:textColor="#E6FFFFFF"
                            android:textSize="14sp"
                            tools:text="Until 01/07/2026" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Status detail card: activation + expiry + progress + countdown (active only) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStatusDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/vip_card_bg"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/vip_card_stroke"
                    app:strokeWidth="1dp"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- [5] Countdown text -->
                        <TextView
                            android:id="@+id/tvCountdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/vip_gold"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            tools:text="12d 03h 24m 15s" />

                        <!-- [4] Progress bar (elapsed) -->
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressVip"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            app:indicatorColor="@color/vip_gold"
                            app:trackColor="#33FFFFFF"
                            app:trackCornerRadius="5dp"
                            app:trackThickness="10dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="18dp"
                            android:background="@color/vip_card_stroke" />

                        <!-- [2] Activation date row -->
                        <TextView
                            android:id="@+id/tvActivatedAt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical"
                            android:textColor="@color/vip_text_secondary"
                            android:textSize="14sp"
                            tools:text="Activated: 01/06/2026 10:00" />

                        <!-- [3] Expiry date row -->
                        <TextView
                            android:id="@+id/tvExpiresAt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical"
                            android:textColor="@color/vip_text_secondary"
                            android:textSize="14sp"
                            tools:text="Expires: 01/07/2026 10:00" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- [12] Active VIP card (single entry) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardActiveVip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/vip_card_bg"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/vip_card_stroke"
                    app:strokeWidth="1dp"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvEntryLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/vip_gold"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="🎁 New install gift" />

                            <TextView
                                android:id="@+id/tvEntryRemaining"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/vip_text_secondary"
                                android:textSize="13sp"
                                tools:text="3 days left" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRevoke"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/vip_revoke_all_button"
                            android:textColor="@color/game_red_danger" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ══ Section: Get VIP (key + watch ad) — free state only ══ -->
                <TextView
                    android:id="@+id/tvSectionGet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginStart="4dp"
                    android:text="@string/vip_section_get"
                    android:textAllCaps="true"
                    android:textColor="@color/vip_gold"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGetVip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@color/vip_card_bg"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/vip_card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- [6] Enter VIP key — rounded filled box -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilKey"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/vip_redeem_label"
                            android:textColorHint="@color/vip_text_secondary"
                            app:boxBackgroundColor="@color/vip_input_bg"
                            app:boxCornerRadiusBottomEnd="14dp"
                            app:boxCornerRadiusBottomStart="14dp"
                            app:boxCornerRadiusTopEnd="14dp"
                            app:boxCornerRadiusTopStart="14dp"
                            app:boxStrokeColor="@color/vip_box_stroke"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="2dp"
                            app:endIconMode="clear_text"
                            app:endIconTint="@color/vip_text_secondary"
                            app:hintTextColor="@color/vip_gold"
                            app:startIconDrawable="@drawable/ic_confirmation_number"
                            app:startIconTint="@color/vip_gold">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etKey"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textVisiblePassword"
                                android:letterSpacing="0.03"
                                android:maxLines="1"
                                android:paddingVertical="14dp"
                                android:textColor="@color/white"
                                android:textColorHighlight="@color/vip_gold_deep"
                                android:textSize="16sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Activate: filled gold, chỉ enable khi đã nhập key (logic ở VipActivity) -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnActivate"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="12dp"
                            android:enabled="false"
                            android:text="@string/vip_redeem_button"
                            android:textColor="@color/vip_activate_text"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/vip_activate_bg"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/ic_confirmation_number"
                            app:iconGravity="textStart"
                            app:iconTint="@color/vip_activate_text" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="16dp"
                            android:background="@color/vip_card_stroke" />

                        <!-- [7] Watch ad → 3 days VIP (primary CTA) -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnWatchAd"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginHorizontal="6dp"
                            android:backgroundTint="@color/vip_gold"
                            android:text="@string/vip_watch_ad_3d"
                            android:textColor="@color/vip_on_gold"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/ic_play_circle"
                            app:iconGravity="textStart"
                            app:iconTint="@color/vip_on_gold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ══ Section: Premium plans (buy + restore, disabled — coming soon) ══ -->
                <TextView
                    android:id="@+id/tvSectionPlans"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginStart="4dp"
                    android:text="@string/vip_section_plans"
                    android:textAllCaps="true"
                    android:textColor="@color/game_text_muted"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPlans"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@color/vip_card_bg"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1FFFFFFF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <!-- [8-11] Buy VIP (disabled, IAP coming soon) -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBuy30d"
                            style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:enabled="false"
                            android:text="@string/vip_buy_30d_locked"
                            android:textColor="@color/vip_text_secondary"
                            app:icon="@drawable/ic_card_giftcard"
                            app:iconTint="@color/vip_gold_deep"
                            app:strokeColor="#26FFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBuy90d"
                            style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:enabled="false"
                            android:text="@string/vip_buy_90d_locked"
                            android:textColor="@color/vip_text_secondary"
                            app:icon="@drawable/ic_card_giftcard"
                            app:iconTint="@color/vip_gold_deep"
                            app:strokeColor="#26FFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBuy1y"
                            style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:enabled="false"
                            android:text="@string/vip_buy_1y_locked"
                            android:textColor="@color/vip_text_secondary"
                            app:icon="@drawable/ic_card_giftcard"
                            app:iconTint="@color/vip_gold_deep"
                            app:strokeColor="#26FFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBuyLifetime"
                            style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:enabled="false"
                            android:text="@string/vip_buy_lifetime_locked"
                            android:textColor="@color/vip_text_secondary"
                            app:icon="@drawable/ic_card_giftcard"
                            app:iconTint="@color/vip_gold_deep"
                            app:strokeColor="#26FFFFFF" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="8dp"
                            android:background="#1FFFFFFF" />

                        <!-- [13] Restore purchase (disabled) -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRestore"
                            style="@style/Widget.Material3.Button.TextButton.Icon"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:enabled="false"
                            android:text="@string/vip_restore_locked"
                            android:textColor="@color/vip_text_secondary"
                            app:icon="@drawable/ic_restore"
                            app:iconTint="@color/vip_text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Revoke all VIP (enabled only when VIP active) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRevokeAll"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/vip_revoke_all_button"
                    android:textColor="@color/game_red_danger" />

                <!-- Privacy footer: policy URL + GDPR re-consent (EEA) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvPrivacy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?selectableItemBackgroundBorderless"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp"
                        android:text="@string/privacy_policy"
                        android:textColor="@color/vip_text_secondary"
                        android:textSize="13sp" />

                    <View
                        android:id="@+id/privacyDivider"
                        android:layout_width="1dp"
                        android:layout_height="14dp"
                        android:background="@color/vip_input_stroke" />

                    <TextView
                        android:id="@+id/tvPrivacyOptions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?selectableItemBackgroundBorderless"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp"
                        android:text="@string/privacy_options"
                        android:textColor="@color/vip_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- [anim #5] Confetti overlay -->
    <nl.dionsegijn.konfetti.xml.KonfettiView
        android:id="@+id/viewKonfetti"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false" />
</FrameLayout>
