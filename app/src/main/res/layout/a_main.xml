<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game_gradient"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context="com.saigonphantomlabs.MainActivity">

    <!-- Background GIF overlay -->
    <ImageView
        android:id="@+id/ivBkg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/app_name"
        android:scaleType="centerCrop"
        android:alpha="0.18"
        tools:src="@drawable/ic_bkg_1" />

    <!-- Corner glow top-left (fire) -->
    <View
        android:id="@+id/cornerGlowTL"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="top|start"
        android:background="@drawable/bg_particle_glow"
        android:alpha="0.6"
        android:translationX="-80dp"
        android:translationY="-80dp" />

    <!-- Corner glow bottom-right (fire) -->
    <View
        android:id="@+id/cornerGlowBR"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="bottom|end"
        android:background="@drawable/bg_particle_glow"
        android:alpha="0.5"
        android:translationX="80dp"
        android:translationY="80dp" />

    <!-- Corner glow top-right (cyan) -->
    <View
        android:id="@+id/cornerGlowTR"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:background="@drawable/bg_splash_ring"
        android:alpha="0.3"
        android:translationX="60dp"
        android:translationY="-60dp" />

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingBottom="16dp">

        <!-- Top Section: Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="#20000000">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:text="@string/chess_master_styled"
                android:fontFamily="@font/exo2"
                android:textColor="@color/game_gold_primary"
                android:textSize="12sp"
                android:letterSpacing="0.2"
                android:shadowColor="@color/game_gold_glow"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="8" />

            <TextView
                android:id="@+id/tvVersionTop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:textColor="@color/game_text_muted"
                android:fontFamily="@font/exo2"
                android:textSize="12sp"
                tools:text="v2026.04" />
        </FrameLayout>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.8" />

        <!-- Logo Area with rings -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Logo glow rings container -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="vertical"
                android:gravity="center"
                android:clipChildren="false"
                android:clipToPadding="false">

                <FrameLayout
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- Outer ring -->
                    <View
                        android:id="@+id/logoRing2"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_splash_ring"
                        android:alpha="0.6" />

                    <!-- Inner ring -->
                    <View
                        android:id="@+id/logoRing1"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_splash_ring"
                        android:alpha="0.8" />

                    <!-- Particle glow -->
                    <View
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_particle_glow" />

                    <!-- Logo icon -->
                    <ImageView
                        android:id="@+id/ivMainLogo"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_kingw"
                        app:tint="@color/game_gold_primary"
                        android:contentDescription="@string/app_name" />
                </FrameLayout>

                <!-- Title -->
                <TextView
                    android:id="@+id/tvMainTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/chess_master"
                    android:fontFamily="@font/cinzel"
                    android:textColor="@color/game_gold_light"
                    android:textSize="@dimen/game_title_text_size"
                    android:textStyle="bold"
                    android:shadowColor="@color/game_gold_glow"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="32" />
            </LinearLayout>
        </FrameLayout>

        <!-- Middle Section: Game Mode Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingHorizontal="32dp">

            <!-- Play PvP Button (Primary) with shimmer overlay -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_game"
                android:layout_marginBottom="16dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/btnPlayPvP"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_btn_pvp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_play"
                        app:tint="@color/game_gold_primary"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/play_pvp"
                        android:fontFamily="@font/cinzel"
                        android:textColor="@color/game_gold_light"
                        android:textSize="@dimen/game_button_text_size"
                        android:textStyle="bold"
                        android:shadowColor="@color/game_gold_glow"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="20" />
                </LinearLayout>

                <!-- Shimmer sweep overlay: match_parent for full-width sweep -->
                <View
                    android:id="@+id/shimmerPvP"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_shimmer_white"
                    android:translationX="-600dp" />
            </FrameLayout>

            <!-- Play AI Button (Secondary) with shimmer overlay -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_game"
                android:layout_marginBottom="24dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/btnPlayPvE"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_btn_pve"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_puzzle"
                        app:tint="@color/game_neon_cyan"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/play_ai"
                        android:fontFamily="@font/cinzel"
                        android:textColor="@color/white"
                        android:textSize="@dimen/game_button_text_size"
                        android:textStyle="bold"
                        android:shadowColor="@color/game_cyan_glow"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="20" />
                </LinearLayout>

                <!-- Shimmer sweep overlay: match_parent for full-width sweep -->
                <View
                    android:id="@+id/shimmerPvE"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_shimmer_white"
                    android:translationX="-600dp" />
            </FrameLayout>

            <!-- Stats & Rules Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Stats Button -->
                <LinearLayout
                    android:id="@+id/btnStats"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_game_compact"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_btn_secondary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_trophy"
                        app:tint="@color/game_gold_primary"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats"
                        android:fontFamily="@font/exo2"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:shadowColor="#88FFFFFF"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="12" />
                </LinearLayout>

                <!-- Rules Button -->
                <LinearLayout
                    android:id="@+id/btnRules"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_game_compact"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_btn_secondary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_rules"
                        app:tint="@color/game_text_muted"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rules"
                        android:fontFamily="@font/exo2"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:shadowColor="#88FFFFFF"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="12" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnLanguage"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_game_compact"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_btn_secondary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCurrentLanguage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/language_en_placeholder"
                    android:fontFamily="@font/exo2"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:shadowColor="#88FFFFFF"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="12" />
            </LinearLayout>

        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Bottom Section: Action Buttons (Rate, More, Share) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingBottom="16dp">

            <!-- Rate App -->
            <LinearLayout
                android:id="@+id/btnRateApp"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_btn_secondary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_star"
                    app:tint="@color/game_gold_primary"
                    android:contentDescription="@null" />
            </LinearLayout>

            <!-- More Apps -->
            <LinearLayout
                android:id="@+id/btnMoreApps"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_btn_secondary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_apps"
                    app:tint="@color/game_text_muted"
                    android:contentDescription="@null" />
            </LinearLayout>

            <!-- Share App -->
            <LinearLayout
                android:id="@+id/btnShareApp"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_btn_secondary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_share"
                    app:tint="@color/game_text_muted"
                    android:contentDescription="@null" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</FrameLayout>