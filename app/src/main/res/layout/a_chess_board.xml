<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/backgroundLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game_gradient"
    tools:context="com.saigonphantomlabs.ChessBoardActivity">

    <!-- Turn Glow Overlay - White -->
    <View android:id="@+id/whiteTurnGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_glow_turn_white"
        android:alpha="0" />

    <!-- Turn Glow Overlay - Black -->
    <View android:id="@+id/blackTurnGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_glow_turn_black"
        android:alpha="0" />

    <!-- Captured pieces for Black (shows WHITE pieces captured by black) -->
    <HorizontalScrollView
        android:id="@+id/capturedBlackPieces"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_captured_black"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/capturedBlackPiecesContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp" />
    </HorizontalScrollView>

    <!-- Turn Indicator for Black -->
    <LinearLayout
        android:id="@+id/blackTurnIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:background="@drawable/bg_pill_turn_black"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/capturedBlackPieces">
        
        <View
            android:id="@+id/blackTurnDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_turn_indicator_black"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BLACK TURN"
            android:fontFamily="@font/exo2"
            android:textColor="@color/game_neon_cyan"
            android:textSize="12sp"
            android:textStyle="bold"
            android:shadowColor="@color/game_cyan_glow"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="16" />
    </LinearLayout>

    <!-- Glowing Aura behind the Board -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_board_glow"
        android:layout_margin="-4dp"
        app:layout_constraintTop_toTopOf="@id/boardLayout"
        app:layout_constraintBottom_toBottomOf="@id/boardLayout"
        app:layout_constraintStart_toStartOf="@id/boardLayout"
        app:layout_constraintEnd_toEndOf="@id/boardLayout" />

    <!-- Chess Board - FIXED POSITION using vertical bias -->
    <FrameLayout
        android:id="@+id/boardLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/game_bg_elevated"
        app:layout_constraintBottom_toTopOf="@id/whiteTurnIndicator"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/blackTurnIndicator"
        app:layout_constraintVertical_bias="0.5">

        <ImageView
            android:id="@+id/boardImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/ic_chessboard"
            android:contentDescription="@string/app_name" />
    </FrameLayout>

    <!-- Turn Indicator for White -->
    <LinearLayout
        android:id="@+id/whiteTurnIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="invisible"
        android:background="@drawable/bg_pill_turn_white"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toTopOf="@id/capturedWhitePieces"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        
        <View
            android:id="@+id/whiteTurnDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_turn_indicator_white"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WHITE TURN"
            android:fontFamily="@font/exo2"
            android:textColor="@color/game_gold_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:shadowColor="@color/game_gold_glow"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="16" />
    </LinearLayout>

    <!-- Captured pieces for White (shows BLACK pieces captured by white) -->
    <HorizontalScrollView
        android:id="@+id/capturedWhitePieces"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_captured_white"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/buttonContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/capturedWhitePiecesContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp" />
    </HorizontalScrollView>

    <!-- Button Container -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="wrap_content"
        android:layout_height="64dp"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/ad_layout_include"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Restart Button - Always visible -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRestart"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:text="@string/play_again"
            android:textColor="@color/game_text_muted"
            android:fontFamily="@font/exo2"
            android:visibility="gone"
            android:background="@drawable/bg_btn_secondary"
            android:drawableStart="@drawable/ic_restart"
            android:drawablePadding="8dp"
            android:drawableTint="@color/game_text_muted"
            android:paddingHorizontal="24dp"
            android:textAllCaps="false"/>

        <!-- Undo Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnUndo"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/undo"
            android:textColor="@color/white"
            android:fontFamily="@font/exo2"
            android:visibility="gone"
            android:background="@drawable/bg_btn_pve"
            android:drawableStart="@drawable/ic_undo"
            android:drawablePadding="8dp"
            android:drawableTint="@color/white"
            android:paddingHorizontal="24dp"
            android:textAllCaps="false"
            android:shadowColor="@color/game_cyan_glow"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="12"/>

    </LinearLayout>

    <include
        android:id="@+id/ad_layout_include"
        layout="@layout/layout_ad_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
