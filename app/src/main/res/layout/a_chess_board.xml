<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/backgroundLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_game_gradient"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context="com.saigonphantomlabs.ChessBoardActivity">

    <!-- Turn Glow Overlays — full screen, behind everything -->
    <View android:id="@+id/whiteTurnGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_glow_turn_white"
        android:alpha="0" />

    <View android:id="@+id/blackTurnGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_glow_turn_black"
        android:alpha="0" />

    <!-- Corner glows (decorative, can overflow, parent clipChildren=false) -->
    <View
        android:id="@+id/cornerGlowTR"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:background="@drawable/bg_particle_glow"
        android:alpha="0.3"
        android:translationX="60dp"
        android:translationY="-60dp" />

    <View
        android:id="@+id/cornerGlowBL"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="bottom|start"
        android:background="@drawable/bg_particle_glow"
        android:alpha="0.25"
        android:translationX="-60dp"
        android:translationY="60dp" />

    <!-- Main vertical chain — NO overlap guaranteed -->
    <LinearLayout
        android:id="@+id/mainContentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Captured Black row -->
        <HorizontalScrollView
            android:id="@+id/capturedBlackPieces"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="36dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_captured_black"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/capturedBlackPiecesContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp" />
        </HorizontalScrollView>

        <!-- Black Turn Indicator — clipChildren=false so dot pulse doesn't clip -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:clipChildren="false"
            android:clipToPadding="false">
            <LinearLayout
                android:id="@+id/blackTurnIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/bg_pill_turn_black"
                android:paddingHorizontal="20dp"
                android:paddingVertical="6dp">
                <View
                    android:id="@+id/blackTurnDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_turn_indicator_black"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/black_turn"
                    android:fontFamily="@font/exo2"
                    android:textColor="@color/game_neon_cyan"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:shadowColor="@color/game_cyan_glow"
                    android:shadowDx="0" android:shadowDy="0" android:shadowRadius="20" />
            </LinearLayout>
            <!-- Đồng hồ đen (chess clock) — ẩn khi không bật giờ -->
            <TextView
                android:id="@+id/tvBlackClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_pill_turn_black"
                android:fontFamily="@font/exo2"
                android:paddingHorizontal="14dp"
                android:paddingVertical="4dp"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="5:00" />
        </FrameLayout>

        <!--
          BOARD SECTION — ConstraintLayout ensures PERFECT 1:1 square.
          weight=1 fills remaining space; board inside is dimensionRatio="1:1"
          → board is always min(parentW, parentH) × min(parentW, parentH).
          clipChildren=false allows boardPulse animation to overflow slightly.
        -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/boardContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false">

            <FrameLayout
                android:id="@+id/boardLayout"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/boardImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/ic_chessboard"
                    android:contentDescription="@string/app_name" />
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- White Turn Indicator -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:clipChildren="false"
            android:clipToPadding="false">
            <LinearLayout
                android:id="@+id/whiteTurnIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="invisible"
                android:background="@drawable/bg_pill_turn_white"
                android:paddingHorizontal="20dp"
                android:paddingVertical="6dp">
                <View
                    android:id="@+id/whiteTurnDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_turn_indicator_white"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/white_turn"
                    android:fontFamily="@font/exo2"
                    android:textColor="@color/game_gold_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:shadowColor="@color/game_gold_glow"
                    android:shadowDx="0" android:shadowDy="0" android:shadowRadius="20" />
            </LinearLayout>
            <!-- Đồng hồ trắng (chess clock) — ẩn khi không bật giờ -->
            <TextView
                android:id="@+id/tvWhiteClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_pill_turn_white"
                android:fontFamily="@font/exo2"
                android:paddingHorizontal="14dp"
                android:paddingVertical="4dp"
                android:textColor="@color/game_bg_deep"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="5:00" />
        </FrameLayout>

        <!-- Captured White row -->
        <HorizontalScrollView
            android:id="@+id/capturedWhitePieces"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/bg_captured_white"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/capturedWhitePiecesContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp" />
        </HorizontalScrollView>

        <!-- Action Buttons trong HorizontalScrollView: căn giữa khi vừa màn, cuộn ngang khi
             nhiều nút (theme/restart/undo/hint) — KHÔNG bao giờ clip nút (fix wrap-width). -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:fillViewport="true"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/buttonContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Board theme picker — same style as btnUndo for visual consistency -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBoardTheme"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="@string/theme_select"
                    android:textColor="@color/white"
                    android:fontFamily="@font/exo2"
                    android:background="@drawable/bg_btn_pve"
                    android:paddingHorizontal="12dp"
                    android:textAllCaps="false"
                    android:shadowColor="@color/game_cyan_glow"
                    android:shadowDx="0" android:shadowDy="0" android:shadowRadius="12"
                    android:layout_marginEnd="8dp" />

                <!-- Restart icon-only (ImageButton → icon CĂN GIỮA chuẩn; bg đồng nhất nhóm icon) -->
                <ImageButton
                    android:id="@+id/btnRestart"
                    android:layout_width="48dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@string/play_again"
                    android:visibility="gone"
                    android:background="@drawable/bg_btn_secondary"
                    android:scaleType="center"
                    android:src="@drawable/ic_restart"
                    android:tint="@color/white" />

                <!-- Undo icon-only -->
                <ImageButton
                    android:id="@+id/btnUndo"
                    android:layout_width="48dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@string/undo"
                    android:visibility="gone"
                    android:background="@drawable/bg_btn_secondary"
                    android:scaleType="center"
                    android:src="@drawable/ic_undo"
                    android:tint="@color/white" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnHint"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="@string/hint"
                    android:textColor="@color/vip_on_gold"
                    android:fontFamily="@font/exo2"
                    android:background="@drawable/bg_btn_pve"
                    android:backgroundTint="@color/vip_gold"
                    android:drawableStart="@drawable/ic_hint"
                    android:drawablePadding="6dp"
                    android:drawableTint="@color/vip_on_gold"
                    android:paddingHorizontal="12dp"
                    android:textAllCaps="false" />

                <!-- Moves/PGN icon-only -->
                <ImageButton
                    android:id="@+id/btnMoves"
                    android:layout_width="48dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/moves_title"
                    android:background="@drawable/bg_btn_secondary"
                    android:scaleType="center"
                    android:src="@drawable/ic_moves"
                    android:tint="@color/white" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Ad Banner -->
        <include
            android:id="@+id/ad_layout_include"
            layout="@layout/layout_ad_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</FrameLayout>
