<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B30D0D0F"
    tools:context="com.saigonphantomlabs.PawnPromotionActivity">

    <ImageView
        android:id="@+id/ivBkg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/promotionQuestion"
            android:textAlignment="center"
            android:textColor="@color/game_gold_light"
            android:fontFamily="@font/cinzel"
            android:textSize="24sp"
            android:textStyle="bold"
            android:shadowColor="@color/game_gold_glow"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="24"/>

        <!-- Piece selection grid -->
        <LinearLayout
            android:id="@+id/pieceContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Queen -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQueen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:rippleColor="@color/game_gold_glow"
                app:strokeColor="@android:color/transparent"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_promotion_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/btnQueen"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/queen"
                        android:src="@drawable/ic_queenw" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/queen"
                        android:fontFamily="@font/exo2"
                        android:textColor="@color/game_gold_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:shadowColor="@color/game_gold_glow"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Rook -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRook"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:rippleColor="@color/game_gold_glow"
                app:strokeColor="@android:color/transparent"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_promotion_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/btnRook"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/rook"
                        android:src="@drawable/ic_rookw" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/rook"
                        android:fontFamily="@font/exo2"
                        android:textColor="@color/game_gold_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:shadowColor="@color/game_gold_glow"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bishop -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBishop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:rippleColor="@color/game_gold_glow"
                app:strokeColor="@android:color/transparent"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_promotion_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/btnBishop"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/bishop"
                        android:src="@drawable/ic_bishopw" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/bishop"
                        android:fontFamily="@font/exo2"
                        android:textColor="@color/game_gold_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:shadowColor="@color/game_gold_glow"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Knight -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardKnight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:rippleColor="@color/game_gold_glow"
                app:strokeColor="@android:color/transparent"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_promotion_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/btnKnight"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/knight"
                        android:src="@drawable/ic_knightw" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/knight"
                        android:fontFamily="@font/exo2"
                        android:textColor="@color/game_gold_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:shadowColor="@color/game_gold_glow"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</FrameLayout>