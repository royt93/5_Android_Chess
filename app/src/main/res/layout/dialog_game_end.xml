<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_game"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Trophy / outcome icon with glow ring behind it -->
    <FrameLayout
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="16dp"
        android:layout_gravity="center_horizontal">

        <!-- Radial glow behind icon -->
        <View
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_particle_glow" />

        <ImageView
            android:id="@+id/dialog_icon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_trophy"
            app:tint="@color/game_gold_primary" />
    </FrameLayout>

    <TextView
        android:id="@+id/dialog_title"
        style="@style/GameText.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/white_wins"
        android:shadowColor="@color/game_gold_glow"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="24" />

    <TextView
        android:id="@+id/dialog_message"
        style="@style/GameText.Body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="@string/black_loses" />

    <!-- Stats Container with neon border -->
    <LinearLayout
        android:id="@+id/stats_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_btn_secondary"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            style="@style/GameText.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/stats_title"
            android:shadowColor="@color/game_cyan_glow"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="8" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <TextView
                style="@style/GameText.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stats_duration_label" />

            <TextView
                android:id="@+id/stats_duration_value"
                style="@style/GameText.Body"
                android:textColor="@color/game_gold_primary"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="05:23"
                android:shadowColor="@color/game_gold_glow"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="8" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <TextView
                style="@style/GameText.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stats_moves_label" />

            <TextView
                android:id="@+id/stats_moves_value"
                style="@style/GameText.Body"
                android:textColor="@color/game_gold_primary"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="42"
                android:shadowColor="@color/game_gold_glow"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="8" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <TextView
                style="@style/GameText.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stats_captured_white_label" />

            <TextView
                android:id="@+id/stats_white_captured_value"
                style="@style/GameText.Body"
                android:textColor="@color/game_white_piece"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                style="@style/GameText.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stats_captured_black_label" />

            <TextView
                android:id="@+id/stats_black_captured_value"
                style="@style/GameText.Body"
                android:textColor="@color/game_white_piece"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6" />
        </LinearLayout>
    </LinearLayout>

    <!-- Review Board button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_review"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/cinzel"
            android:text="@string/review_board"
            android:textColor="@color/game_gold_primary"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:strokeColor="@color/game_gold_primary"
            app:strokeWidth="1dp" />

    </LinearLayout>

    <!-- Exit / Play Again -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_exit"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/exo2"
            android:text="@string/exit"
            android:textColor="@color/game_red_danger"
            app:cornerRadius="12dp"
            app:strokeColor="#00000000" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_play_again"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/cinzel"
            android:text="@string/play_again"
            android:textColor="@color/game_bg_deep"
            android:textStyle="bold"
            app:backgroundTint="@color/game_gold_primary"
            app:cornerRadius="12dp" />
    </LinearLayout>

</LinearLayout>
