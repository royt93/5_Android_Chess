<?xml version="1.0" encoding="utf-8"?>
<!-- bg_promotion_card: NO negative insets. Gold rings nested inward. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer gold ring inside bounds -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#00000000" />
            <stroke android:width="2dp" android:color="#50D4AF37" />
        </shape>
    </item>
    <!-- Mid warm ring -->
    <item android:top="4dp" android:left="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#40FF8C00" />
        </shape>
    </item>
    <!-- Dark fire gradient body -->
    <item android:top="7dp" android:left="7dp" android:right="7dp" android:bottom="7dp">
        <shape android:shape="rectangle">
            <corners android:radius="13dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#CC1A0800"
                android:endColor="#EE080400" />
        </shape>
    </item>
</layer-list>
