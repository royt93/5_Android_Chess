<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <!-- Glass Gradient: Dark Blue -->
            <gradient
                android:startColor="#E61976D2"
                android:endColor="#E60D47A1"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#80FFFFFF" />
        </shape>
    </item>

    <!-- Normal state -->
    <item>
        <shape android:shape="rectangle">
            <!-- Glass Gradient: Vibrant Blue -->
            <gradient
                android:startColor="#E642A5F5"
                android:endColor="#E61E88E5"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="16dp" />
            <stroke android:width="1.5dp" android:color="#80FFFFFF" />
        </shape>
    </item>
</selector>