<?xml version="1.0" encoding="utf-8"?>
<!-- Nút VIP khi đã active: gold-filled (báo trạng thái ngay trên nút crown, không cần chip header). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow ring vàng mờ -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#00000000" />
            <stroke android:width="1.5dp" android:color="#66FFD60A" />
        </shape>
    </item>
    <!-- Body gold -->
    <item android:top="3dp" android:left="3dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/vip_gold"
                android:endColor="@color/vip_gold_deep" />
            <corners android:radius="13dp" />
            <stroke android:width="1dp" android:color="#FFFFE082" />
        </shape>
    </item>
</layer-list>
