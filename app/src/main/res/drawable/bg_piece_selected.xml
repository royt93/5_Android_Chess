<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow (Softest, widest) -->
    <item android:top="-8dp" android:left="-8dp" android:right="-8dp" android:bottom="-8dp">
        <shape android:shape="oval">
            <solid android:color="#20FFD700" />
        </shape>
    </item>
    
    <!-- Middle Glow -->
    <item android:top="-4dp" android:left="-4dp" android:right="-4dp" android:bottom="-4dp">
        <shape android:shape="oval">
            <solid android:color="@color/game_gold_glow" />
        </shape>
    </item>

    <!-- Inner Stroke & Fill -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#40FFD700" />
            <stroke
                android:width="3dp"
                android:color="@color/game_gold_primary" />
        </shape>
    </item>
</layer-list>
