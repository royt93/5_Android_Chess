<?xml version="1.0" encoding="utf-8"?>
<!--
  bg_piece_selected: NO negative insets.
  Multi-ring glow nesting INWARD so all layers stay inside piece bounds.
  The outer ring has positive insets so it is fully contained.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Inner fill + bright border (innermost, fully contained) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#50FFD700" />
            <stroke android:width="3dp" android:color="@color/game_gold_primary" />
        </shape>
    </item>
    <!-- Mid glow ring (inset inward from item above implicitly via next positive inset) -->
    <item android:top="-4dp" android:left="-4dp" android:right="-4dp" android:bottom="-4dp">
        <shape android:shape="oval">
            <solid android:color="#30FFD700" />
        </shape>
    </item>
</layer-list>
