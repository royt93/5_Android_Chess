<?xml version="1.0" encoding="utf-8"?>
<!-- White turn: intense gold radial bottom glow + full-screen gradient sweep -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom radial gold burst (from bottom center) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:centerX="0.5"
                android:centerY="1.0"
                android:startColor="#50FFD700"
                android:centerColor="#20D4AF37"
                android:endColor="#00000000" />
        </shape>
    </item>
    <!-- Full-screen warm tint overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#00000000"
                android:centerColor="#08FF8C00"
                android:endColor="#14FFD700" />
        </shape>
    </item>
</layer-list>
