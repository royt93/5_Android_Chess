<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glass Background: Semi-transparent white (High opacity for readability) -->
    <gradient
        android:startColor="#F2FFFFFF"
        android:endColor="#D9FFFFFF"
        android:angle="135"
        android:type="linear" />
    
    <corners android:radius="24dp" />
    
    <!-- Glass Border -->
    <stroke 
        android:width="1.5dp" 
        android:color="#B3FFFFFF" />
    
    <padding
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp" />
</shape>
