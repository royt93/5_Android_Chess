<?xml version="1.0" encoding="utf-8"?>
<!-- NO negative insets. All layers inside view bounds. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring inside bounds -->
    <item android:top="0dp" android:left="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <stroke android:width="2dp" android:color="#60D4AF37" />
            <solid android:color="#00000000" />
        </shape>
    </item>
    <!-- Inner body -->
    <item android:top="4dp" android:left="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#C016213E" />
            <corners android:radius="24dp" />
            <stroke android:width="1.5dp" android:color="#CCD4AF37" />
        </shape>
    </item>
</layer-list>
