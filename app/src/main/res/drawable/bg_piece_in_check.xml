<?xml version="1.0" encoding="utf-8"?>
<!--
  bg_piece_in_check: NO large negative insets.
  Danger glow contained within minimal overflow (-4dp only).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Inner fill + danger red border — fully inside bounds -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#50FF4444" />
            <stroke android:width="3dp" android:color="#FF0000" />
        </shape>
    </item>
    <!-- Subtle outer danger aura — minimal overflow only -->
    <item android:top="-4dp" android:left="-4dp" android:right="-4dp" android:bottom="-4dp">
        <shape android:shape="oval">
            <solid android:color="#40FF2A00" />
        </shape>
    </item>
</layer-list>
