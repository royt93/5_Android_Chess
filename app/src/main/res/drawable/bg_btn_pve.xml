<?xml version="1.0" encoding="utf-8"?>
<!-- bg_btn_pve: NO negative insets. Cyan glow rings inside bounds using positive insets. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outermost cyan glow inside bounds -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#00000000" />
            <stroke android:width="2dp" android:color="#3000FFFF" />
        </shape>
    </item>
    <!-- Mid cyan ring -->
    <item android:top="3dp" android:left="3dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="17dp" />
            <solid android:color="#00000000" />
            <stroke android:width="1.5dp" android:color="#5000DDFF" />
        </shape>
    </item>
    <!-- Cold fire gradient body -->
    <item android:top="6dp" android:left="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#0055AA"
                android:centerColor="#CC001133"
                android:endColor="#990A0015" />
            <stroke android:width="1dp" android:color="#CC00CCFF" />
        </shape>
    </item>
</layer-list>
