<?xml version="1.0" encoding="utf-8"?>
<!-- Black turn: intense cyan radial top glow + cold blue screen sweep -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Top radial cyan burst (from top center) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:centerX="0.5"
                android:centerY="0.0"
                android:startColor="#5000FFFF"
                android:centerColor="#2000AAFF"
                android:endColor="#00000000" />
        </shape>
    </item>
    <!-- Full-screen cold tint overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#00000000"
                android:centerColor="#080055FF"
                android:endColor="#1200FFFF" />
        </shape>
    </item>
</layer-list>
